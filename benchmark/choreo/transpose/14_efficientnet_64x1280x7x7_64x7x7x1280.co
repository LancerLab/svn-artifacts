#include "choreo.h"
#include "common.h"

__co__ auto TRANSPOSE(f32 [64, 1280, 7, 7] i) {
  f32 [i.span(0), i.span(2), i.span(3), i.span(1)] o;
  parallel p by 2  {
    parallel q by 4  {
      foreach {x, y} in [i.span(0)/#p/#q, i.span(1)] {
        l = dma.transp<0, 2, 3, 1> i.chunkat(p#q#x, y, _, _) => local;
        dma.copy l.data => o.chunkat(p#q#x, _, _, y);
      }
    }
  }
  return o;
}

int main() {
  test4("TRANSPOSE", TRANSPOSE, {64, 1280, 7, 7}, {0, 2, 3, 1});
}