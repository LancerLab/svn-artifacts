#include "common.hpp"

// case15: [16, 1024, 1536] + [1536, 6144] --> [16, 1024, 6144] (GPT)
__co__ auto matmul15(f32 [16, 1024, 1536] lhs, f32 [1536, 6144] rhs) {
  f32 [lhs.span(0), lhs.span(1), rhs.span(1)] output;
  parallel p by 4, q by 4 {
    with index = {m_tile, n_tile, k_tile} in [128, 768, 1] {
      foreach m_tile, n_tile {
        local f32[output.span(0)/#p/#q, output.span(1)/#m_tile, output.span(2)/#n_tile] l1_out {0.0f};
        foreach k_tile {
          l1_a = dma.copy lhs.chunkat(p#q, m_tile, k_tile) => shared;
          l1_b = dma.transp<1,0> rhs.chunkat(k_tile, n_tile) => shared;
          foreach {i} in [l1_out.span(0)] {
            call k_matmul(l1_a.chunkat(i,_,_), l1_b.data, l1_out, l1_a.span(1), l1_b.span(0), l1_a.span(2));
          }
        }
        dma.copy l1_out => output.chunkat(p#q, m_tile, n_tile);
      }
    }
  }
  return output;
}

int main() {
  TEST2(matmul15, 16, 1024, 6144, 1536);
  return 0;
}
